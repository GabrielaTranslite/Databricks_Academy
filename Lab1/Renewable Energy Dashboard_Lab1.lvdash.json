    },
    {
      "name": "9a21bdef",
      "displayName": "region_coverage",
      "queryLines": [
        "SELECT\r\n",
        "  region,\r\n",
        "  COUNT(DISTINCT country) AS countries_total,\r\n",
        "  COUNT(DISTINCT CASE WHEN renewables_share_energy IS NOT NULL THEN country END) AS countries_with_energy_mix\r\n",
        "FROM dbr_dev.gabrielajaniszews786.owid_energy_enriched\r\n",
        "WHERE year = 2022\r\n",
        "GROUP BY region\r\n",
        "ORDER BY countries_with_energy_mix DESC"
      ]
    }
  ],
